    {
      "name": "Customers",
      "description": "Operations on the customers Firestore collection. Records are auto-created/updated via upsertCustomer() when an order is placed. Phone number is the deduplication key.\n\nKey fields: name, phone (primary key), email, primaryAddress, district, totalOrdersCount (number), lifetimeValue (number LKR), lastOrderDate (timestamp), notes (string), createdAt.",
      "item": [
        {
          "name": "Get All Customers (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"customers\" }],\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"lastOrderDate\" }, \"direction\": \"DESCENDING\" }]\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            }
          }
        },
        {
          "name": "Find Customer by Phone (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"customers\" }],\n    \"where\": {\n      \"fieldFilter\": {\n        \"field\": { \"fieldPath\": \"phone\" },\n        \"op\": \"EQUAL\",\n        \"value\": { \"stringValue\": \"+94771234567\" }\n      }\n    },\n    \"limit\": 1\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            }
          }
        }
      ]
    },
