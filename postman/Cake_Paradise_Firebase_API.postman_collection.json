{
  "info": {
    "_postman_id": "cake-paradise-sayu-2026",
    "name": "Cake Paradise by Sayu (Firebase REST API)",
    "description": "Complete Postman collection for the Cake Paradise by Sayu bakery application.\n\nThis app is serverless â€” it uses the Firebase Client SDK directly in the browser. These requests model the equivalent Firebase REST API calls for testing, inspection, and documentation.\n\nFirestore Collections: products, categories, orders, customInquiries, customers, adminUsers, siteConfig.\n\nExternal Services: Firebase Authentication REST API, Firebase Storage, EmailJS (order + inquiry emails).\n\nHow to use:\n1. Set firebase_project_id variable to your Firebase project ID.\n2. For protected endpoints, run Auth > Sign In and copy the idToken into the id_token variable.\n3. All currency values are in LKR (Sri Lankan Rupees).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "description": "Firebase Authentication REST API. Used by both admin panel and customer-facing portal.",
      "item": [
        {
          "name": "Admin - Sign In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cakeparadisebysayu.com\",\n  \"password\": \"your_admin_password\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebase_web_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signInWithPassword"],
              "query": [{ "key": "key", "value": "{{firebase_web_api_key}}" }]
            },
            "description": "Signs in an admin user. Copy the idToken from the response body and set it as the id_token variable."
          }
        },
        {
          "name": "Customer - Sign In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"customer_password\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebase_web_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signInWithPassword"],
              "query": [{ "key": "key", "value": "{{firebase_web_api_key}}" }]
            }
          }
        },
        {
          "name": "Customer - Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newcustomer@example.com\",\n  \"password\": \"securePassword123\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebase_web_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signUp"],
              "query": [{ "key": "key", "value": "{{firebase_web_api_key}}" }]
            }
          }
        },
        {
          "name": "Get Current User Info",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{id_token}}\"\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:lookup?key={{firebase_web_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:lookup"],
              "query": [{ "key": "key", "value": "{{firebase_web_api_key}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "description": "CRUD operations on the products Firestore collection.\n\nKey fields: name (string), slug (string), description (string), price (number LKR), categoryId (string), parentCategoryId (string), images (array of URLs), status ('active'|'inactive'), isFeatured (boolean), stockStatus ('in-stock'|'out-of-stock'|'made-to-order'), tags (array), createdAt/updatedAt (timestamps).",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/products?pageSize=50",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "products"],
              "query": [{ "key": "pageSize", "value": "50" }]
            },
            "description": "Returns all products. In the app, subscribeToProducts() filters by status=='active' and orders by createdAt desc."
          }
        },
        {
          "name": "Get Single Product by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/products/{{product_id}}",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "Query Products by Category (runQuery)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"products\" }],\n    \"where\": {\n      \"compositeFilter\": {\n        \"op\": \"AND\",\n        \"filters\": [\n          { \"fieldFilter\": { \"field\": { \"fieldPath\": \"categoryId\" }, \"op\": \"EQUAL\", \"value\": { \"stringValue\": \"{{category_id}}\" } } },\n          { \"fieldFilter\": { \"field\": { \"fieldPath\": \"status\" }, \"op\": \"EQUAL\", \"value\": { \"stringValue\": \"active\" } } }\n        ]\n      }\n    },\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"createdAt\" }, \"direction\": \"DESCENDING\" }],\n    \"limit\": 20\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            }
          }
        },
        {
          "name": "Query Featured Products (runQuery)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"products\" }],\n    \"where\": {\n      \"compositeFilter\": {\n        \"op\": \"AND\",\n        \"filters\": [\n          { \"fieldFilter\": { \"field\": { \"fieldPath\": \"isFeatured\" }, \"op\": \"EQUAL\", \"value\": { \"booleanValue\": true } } },\n          { \"fieldFilter\": { \"field\": { \"fieldPath\": \"status\" }, \"op\": \"EQUAL\", \"value\": { \"stringValue\": \"active\" } } }\n        ]\n      }\n    },\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"createdAt\" }, \"direction\": \"DESCENDING\" }],\n    \"limit\": 8\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            }
          }
        },
        {
          "name": "Add Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"name\": { \"stringValue\": \"Chocolate Truffle Cake\" },\n    \"slug\": { \"stringValue\": \"chocolate-truffle-cake\" },\n    \"description\": { \"stringValue\": \"Rich Belgian chocolate cake with ganache frosting.\" },\n    \"price\": { \"doubleValue\": 3500 },\n    \"categoryId\": { \"stringValue\": \"{{category_id}}\" },\n    \"parentCategoryId\": { \"stringValue\": \"cakes\" },\n    \"images\": { \"arrayValue\": { \"values\": [{ \"stringValue\": \"https://firebasestorage.googleapis.com/...\" }] } },\n    \"status\": { \"stringValue\": \"active\" },\n    \"isFeatured\": { \"booleanValue\": false },\n    \"stockStatus\": { \"stringValue\": \"in-stock\" },\n    \"tags\": { \"arrayValue\": { \"values\": [{ \"stringValue\": \"chocolate\" }, { \"stringValue\": \"bestseller\" }] } }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/products",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "products"]
            },
            "description": "Requires admin id_token. In the app, addProduct() also sets createdAt and updatedAt via serverTimestamp()."
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"price\": { \"doubleValue\": 4000 },\n    \"stockStatus\": { \"stringValue\": \"in-stock\" },\n    \"status\": { \"stringValue\": \"active\" }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/products/{{product_id}}?updateMask.fieldPaths=price&updateMask.fieldPaths=stockStatus&updateMask.fieldPaths=status",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "products", "{{product_id}}"],
              "query": [
                { "key": "updateMask.fieldPaths", "value": "price" },
                { "key": "updateMask.fieldPaths", "value": "stockStatus" },
                { "key": "updateMask.fieldPaths", "value": "status" }
              ]
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/products/{{product_id}}",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "products", "{{product_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "description": "Operations on the categories Firestore collection.\n\nKey fields: name (string), slug (string), description (string), parentId (string|null), displayOrder (number), status ('active'|'inactive'), imageUrl (string).",
      "item": [
        {
          "name": "Get All Active Categories",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"categories\" }],\n    \"where\": {\n      \"fieldFilter\": {\n        \"field\": { \"fieldPath\": \"status\" },\n        \"op\": \"EQUAL\",\n        \"value\": { \"stringValue\": \"active\" }\n      }\n    },\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"displayOrder\" }, \"direction\": \"ASCENDING\" }]\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            }
          }
        },
        {
          "name": "Add Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"name\": { \"stringValue\": \"Wedding Cakes\" },\n    \"slug\": { \"stringValue\": \"wedding-cakes\" },\n    \"description\": { \"stringValue\": \"Elegant multi-tiered wedding cakes.\" },\n    \"parentId\": { \"nullValue\": null },\n    \"displayOrder\": { \"integerValue\": \"1\" },\n    \"status\": { \"stringValue\": \"active\" },\n    \"imageUrl\": { \"stringValue\": \"\" }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/categories",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "categories"]
            }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"displayOrder\": { \"integerValue\": \"2\" },\n    \"status\": { \"stringValue\": \"active\" }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/categories/{{category_id}}?updateMask.fieldPaths=displayOrder&updateMask.fieldPaths=status",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "categories", "{{category_id}}"],
              "query": [
                { "key": "updateMask.fieldPaths", "value": "displayOrder" },
                { "key": "updateMask.fieldPaths", "value": "status" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Operations on the orders Firestore collection.\n\nKey fields: orderId (string e.g. ORD-20240624-001), customerInfo (map: name, phone, email, deliveryAddress, district), items (array), totalAmount (number LKR), deliveryFee (number LKR), deliveryMethod ('delivery'|'pickup'), deliveryDate (string), timeSlot ('morning'|'afternoon'|'evening'), paymentMethod ('cod'|'bank-transfer'), orderStatus ('pending-confirmation'|'confirmed'|'in-preparation'|'ready-for-delivery'|'out-for-delivery'|'delivered'|'cancelled'), paymentStatus ('pending'|'paid'), trackHistory (array of {status, timestamp, updatedBy}), specialInstructions (string), emailSent (boolean), createdAt/updatedAt.",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"orderId\": { \"stringValue\": \"ORD-20240624-001\" },\n    \"customerInfo\": {\n      \"mapValue\": {\n        \"fields\": {\n          \"name\": { \"stringValue\": \"Sanjana Perera\" },\n          \"phone\": { \"stringValue\": \"+94771234567\" },\n          \"email\": { \"stringValue\": \"sanjana@example.com\" },\n          \"deliveryAddress\": { \"stringValue\": \"42 Galle Road, Colombo 03\" },\n          \"district\": { \"stringValue\": \"colombo-03\" }\n        }\n      }\n    },\n    \"items\": {\n      \"arrayValue\": {\n        \"values\": [{\n          \"mapValue\": {\n            \"fields\": {\n              \"productId\": { \"stringValue\": \"{{product_id}}\" },\n              \"name\": { \"stringValue\": \"Chocolate Truffle Cake\" },\n              \"price\": { \"doubleValue\": 3500 },\n              \"quantity\": { \"integerValue\": \"1\" },\n              \"customizations\": {\n                \"mapValue\": {\n                  \"fields\": {\n                    \"inscription\": { \"stringValue\": \"Happy Birthday Amali!\" },\n                    \"flavor\": { \"stringValue\": \"chocolate\" }\n                  }\n                }\n              }\n            }\n          }\n        }]\n      }\n    },\n    \"totalAmount\": { \"doubleValue\": 3800 },\n    \"deliveryFee\": { \"doubleValue\": 300 },\n    \"deliveryMethod\": { \"stringValue\": \"delivery\" },\n    \"deliveryDate\": { \"stringValue\": \"2024-06-27\" },\n    \"timeSlot\": { \"stringValue\": \"afternoon\" },\n    \"paymentMethod\": { \"stringValue\": \"cod\" },\n    \"orderStatus\": { \"stringValue\": \"pending-confirmation\" },\n    \"paymentStatus\": { \"stringValue\": \"pending\" },\n    \"specialInstructions\": { \"stringValue\": \"Please handle with care.\" },\n    \"emailSent\": { \"booleanValue\": false }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/orders",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "orders"]
            },
            "description": "In the app, createOrder() auto-generates the orderId (ORD-YYYYMMDD-NNN), appends the initial trackHistory entry with status 'pending-confirmation', and also calls upsertCustomer() to create/update the customer record."
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"orders\" }],\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"createdAt\" }, \"direction\": \"DESCENDING\" }]\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            }
          }
        },
        {
          "name": "Get Orders by Status (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"orders\" }],\n    \"where\": {\n      \"fieldFilter\": {\n        \"field\": { \"fieldPath\": \"orderStatus\" },\n        \"op\": \"EQUAL\",\n        \"value\": { \"stringValue\": \"pending-confirmation\" }\n      }\n    },\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"createdAt\" }, \"direction\": \"DESCENDING\" }]\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents:runQuery",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents:runQuery"]
            },
            "description": "Valid orderStatus values: pending-confirmation, confirmed, in-preparation, ready-for-delivery, out-for-delivery, delivered, cancelled"
          }
        },
        {
          "name": "Get Single Order by Doc ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/orders/{{order_doc_id}}",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "orders", "{{order_doc_id}}"]
            },
            "description": "order_doc_id is the Firestore auto-generated document ID. The human-readable orderId (e.g. ORD-20240624-001) is a field inside the document."
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"orderStatus\": { \"stringValue\": \"confirmed\" }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/orders/{{order_doc_id}}?updateMask.fieldPaths=orderStatus",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "orders", "{{order_doc_id}}"],
              "query": [{ "key": "updateMask.fieldPaths", "value": "orderStatus" }]
            },
            "description": "In the app, updateOrderStatus() also appends to trackHistory and sets paymentStatus='paid' when status becomes 'delivered'."
          }
        }
      ]
    },
    {
      "name": "Custom Inquiries",
      "description": "Operations on the customInquiries Firestore collection. Used for the Custom Order Request form.\n\nKey fields: inquiryId (string e.g. INQ-20240624-001), customerName, customerPhone, customerEmail, cakeType, servings (number), occasion, deliveryDate, designDescription, referenceImages (array), budget (number LKR), quoteStatus ('new'|'viewed'|'quoted'|'accepted'|'rejected'|'converted'), quotedAmount (number|null), adminNotes (string), convertedOrderId (string|null), createdAt/updatedAt.",
      "item": [
        {
          "name": "Submit Custom Inquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"inquiryId\": { \"stringValue\": \"INQ-20240624-001\" },\n    \"customerName\": { \"stringValue\": \"Malsha Fernando\" },\n    \"customerPhone\": { \"stringValue\": \"+94712345678\" },\n    \"customerEmail\": { \"stringValue\": \"malsha@example.com\" },\n    \"cakeType\": { \"stringValue\": \"Wedding Cake\" },\n    \"servings\": { \"integerValue\": \"150\" },\n    \"occasion\": { \"stringValue\": \"Wedding\" },\n    \"deliveryDate\": { \"stringValue\": \"2024-08-15\" },\n    \"designDescription\": { \"stringValue\": \"Three-tier white fondant cake with gold leaf accents and fresh flowers.\" },\n    \"referenceImages\": { \"arrayValue\": { \"values\": [] } },\n    \"budget\": { \"doubleValue\": 25000 },\n    \"quoteStatus\": { \"stringValue\": \"new\" },\n    \"quotedAmount\": { \"nullValue\": null },\n    \"adminNotes\": { \"stringValue\": \"\" },\n    \"convertedOrderId\": { \"nullValue\": null }\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/customInquiries",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "customInquiries"]
            }
          }
        },
        {
          "name": "Get All Inquiries (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structuredQuery\": {\n    \"from\": [{ \"collectionId\": \"customInquiries\" }],\n    \"orderBy\": [{ \"field\": { \"fieldPath\": \"createdAt\" }, \"direction\": \"DESCENDING\" }]\n  }\n}"
            },
            "url": {
