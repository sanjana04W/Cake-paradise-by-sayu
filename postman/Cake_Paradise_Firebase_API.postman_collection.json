    {
      "name": "Firebase Storage",
      "description": "Firebase Storage REST API for managing product and media images.\n\nStorage paths: products/ (product images), media/ (admin Media panel), categories/ (category banners).\n\nNote: In the app, files >2MB are auto-compressed to WebP before upload. The storage.js module uses uploadImage(), uploadMultipleImages(), deleteImage(), and listImages().",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select an image file (JPEG, PNG, WebP). App auto-compresses files >2MB to WebP at 85% quality."
                }
              ]
            },
            "url": {
              "raw": "https://firebasestorage.googleapis.com/v0/b/{{firebase_storage_bucket}}/o?name=products%2F{{image_filename}}",
              "protocol": "https",
              "host": ["firebasestorage", "googleapis", "com"],
              "path": ["v0", "b", "{{firebase_storage_bucket}}", "o"],
              "query": [{ "key": "name", "value": "products%2F{{image_filename}}" }]
            }
          }
        },
        {
          "name": "Get Image Metadata and Download URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "url": {
              "raw": "https://firebasestorage.googleapis.com/v0/b/{{firebase_storage_bucket}}/o/products%2F{{image_filename}}",
              "protocol": "https",
              "host": ["firebasestorage", "googleapis", "com"],
              "path": ["v0", "b", "{{firebase_storage_bucket}}", "o", "products%2F{{image_filename}}"]
            }
          }
        },
        {
          "name": "Delete Image",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{id_token}}" }],
            "url": {
              "raw": "https://firebasestorage.googleapis.com/v0/b/{{firebase_storage_bucket}}/o/products%2F{{image_filename}}",
              "protocol": "https",
              "host": ["firebasestorage", "googleapis", "com"],
              "path": ["v0", "b", "{{firebase_storage_bucket}}", "o", "products%2F{{image_filename}}"]
            }
          }
